<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supernatural Character Gallery</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=UnifrakturCook:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <!-- Navigation Bar -->

    <nav>
        <ul>
            <li><a href="index.html">Home</a></li>
            <li><a href="details.html">Details</a></li>
            <li><a href="about.html">About</a></li>
            <li><a href="new-character-form.html">Add a Character</a></li>
        </ul>
    </nav>

    <!-- Main Content -->
     <main>
        <h1>Supernatural Character Gallery</h1>

        <h3>
            Explore my favorite characters the from hit television show 
            <em>Supernatural</em>
        </h3>

        <!-- Search Bar -->
        <div class="search-bar">
            <input type="text" placeholder="Search by character or species...">

            <button>Search</button>
        </div>
        
        <!-- Character Cards -->
         <section class="gallery">

            <div class="card">
                <img src="Images/sam-winchester.jpg" alt="Sam Winchester">
                <h2>Sam Winchester</h2>
                <p>Human • Hunter</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/dean-winchester.jpg" alt="Dean Winchester">
                <h2>Dean Winchester</h2>
                <p>Human • Hunter</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/castiel.jpg" alt="Castiel">
                <h2>Castiel</h2>
                <p>Angel • Hunter</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/crowley.jpg" alt="Crowley">
                <h2>Crowley</h2>
                <p>Demon • King of Hell</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/bobby-singer.jpg" alt="Bobby Singer">
                <h2>Bobby Singer</h2>
                <p>Human • Hunter</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/charlie-bradbury.jpg" alt="Charlie Bradbury">
                <h2>Charlie Bradbury</h2>
                <p>Human • Hacker</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/kevin-tran.jpg" alt="Kevin Tran">
                <h2>Kevin Tran</h2>
                <p>Human • Prophet</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/death.jpg" alt="Death">
                <h2>Death</h2>
                <p>Horseman • Death</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/ellen-harvelle.jpg" alt="Ellen Harvelle">
                <h2>Ellen Harvelle</h2>
                <p>Human • Hunter</p>
                <a href="details.html">View Details</a>
            </div>

            <div class="card">
                <img src="Images/balthazar.jpg" alt="Balthazar">
                <h2>Balthazar</h2>
                <p>Angel • Entrepreneur</p>
                <a href="details.html">View Details</a>
            </div>
            
        </section>

    </main>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Supernatural Character Gallery. Created as an educational project.</p>
        <p>Supernatural and all related characters are property of their respective owners.</p>
    </footer>

</body>
</html>